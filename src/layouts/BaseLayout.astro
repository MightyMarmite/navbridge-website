---
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  bodyClass?: string;
}
const { title, description, ogImage = '/og-image.png', bodyClass = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" style="background:#0B1929">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0B1929" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={`https://navbridge.io${ogImage}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://navbridge.io${ogImage}`} />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ClientRouter />
  <link rel="stylesheet" href="/fonts/cormorant-garamond.css" />
  <link rel="stylesheet" href="/fonts/dm-sans.css" />
  <link rel="stylesheet" href="/styles/global.css" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "NavBridge",
    "url": "https://navbridge.io",
    "description": "Automated valuation reconciliation for private market portfolios. NavBridge extracts, verifies and reconciles fund manager statements into your master spreadsheet.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock"
    }
  }
  </script>
</head>
<body class={bodyClass}>

  <nav id="nav">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="logo">
          <!-- NavBridge logomark: two nodes connected by a bridge path -->
          <svg class="logo-mark" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="24" width="14" height="16" rx="2" stroke="#00BFA6" stroke-width="2"/>
            <rect x="48" y="24" width="14" height="16" rx="2" stroke="#00BFA6" stroke-width="2"/>
            <path d="M16 28 C24 28 24 20 32 20 C40 20 40 28 48 28" stroke="#00BFA6" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M16 36 C24 36 24 44 32 44 C40 44 40 36 48 36" stroke="#00BFA6" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.45"/>
            <circle cx="32" cy="20" r="3" fill="#00BFA6"/>
            <circle cx="32" cy="44" r="2" fill="#00BFA6" opacity="0.45"/>
            <line x1="32" y1="23" x2="32" y2="41" stroke="#00BFA6" stroke-width="1" stroke-dasharray="2 3" opacity="0.3"/>
          </svg>
          <span class="logo-name">NavBridge</span>
        </a>
        <ul class="nav-links">
          <li><a href="/#how-it-works">How it works</a></li>
          <li><a href="/#features">Features</a></li>
          <li><a href="/#who">Who it's for</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
        <a href="/contact" class="btn-nav">Request Access</a>
        <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    <a href="/#how-it-works">How it works</a>
    <a href="/#features">Features</a>
    <a href="/#who">Who it's for</a>
    <a href="/contact">Contact</a>
    <a href="/contact" class="mobile-cta">Request Access</a>
  </div>

  <slot />

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">
            <svg class="logo-mark" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="2" y="24" width="14" height="16" rx="2" stroke="#33CFBA" stroke-width="2"/>
              <rect x="48" y="24" width="14" height="16" rx="2" stroke="#33CFBA" stroke-width="2"/>
              <path d="M16 28 C24 28 24 20 32 20 C40 20 40 28 48 28" stroke="#33CFBA" stroke-width="2" stroke-linecap="round" fill="none"/>
              <path d="M16 36 C24 36 24 44 32 44 C40 44 40 36 48 36" stroke="#33CFBA" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.45"/>
              <circle cx="32" cy="20" r="3" fill="#33CFBA"/>
              <circle cx="32" cy="44" r="2" fill="#33CFBA" opacity="0.45"/>
              <line x1="32" y1="23" x2="32" y2="41" stroke="#33CFBA" stroke-width="1" stroke-dasharray="2 3" opacity="0.3"/>
            </svg>
            <span class="logo-name" style="color:var(--nb-text-lt);">NavBridge</span>
          </a>
          <p>Automated valuation reconciliation for private market portfolios. Purpose-built for family offices and boutique fund managers.</p>
        </div>
        <div class="footer-col">
          <h4>Product</h4>
          <ul>
            <li><a href="/#how-it-works">How it works</a></li>
            <li><a href="/#features">Features</a></li>
            <li><a href="/#who">Who it's for</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Get started</h4>
          <ul>
            <li><a href="/contact">Request access</a></li>
            <li><a href="/contact">Talk to us</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 NavBridge. All rights reserved.</p>
        <div class="footer-made">
          Built by <a href="https://caelion.consulting" target="_blank" rel="noopener">Caelion Ltd</a>
        </div>
        <div class="footer-legal">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    function initNav() {
      var hamburger = document.getElementById('hamburger');
      var mobileMenu = document.getElementById('mobileMenu');
      if (hamburger && mobileMenu) {
        var newH = hamburger.cloneNode(true);
        hamburger.parentNode.replaceChild(newH, hamburger);
        hamburger = newH;

        hamburger.addEventListener('click', function() {
          var open = mobileMenu.classList.toggle('open');
          hamburger.classList.toggle('open', open);
          hamburger.setAttribute('aria-expanded', String(open));
          mobileMenu.setAttribute('aria-hidden', String(!open));
        });
        document.addEventListener('click', function(e) {
          if (!hamburger.contains(e.target) && !mobileMenu.contains(e.target)) {
            mobileMenu.classList.remove('open');
            hamburger.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
            mobileMenu.setAttribute('aria-hidden', 'true');
          }
        });
      }

      var els = document.querySelectorAll('.reveal');
      if (els.length) {
        if ('IntersectionObserver' in window) {
          var obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
              if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
            });
          }, { threshold: 0, rootMargin: '0px 0px -48px 0px' });
          els.forEach(function(el) { obs.observe(el); });
        } else {
          els.forEach(function(el) { el.classList.add('visible'); });
        }
      }
    }
    document.addEventListener('astro:page-load', initNav);
  </script>

</body>
</html>
